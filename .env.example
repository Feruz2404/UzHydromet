# === Supabase (database + storage) ===
# Public anon credentials (safe to expose to the browser).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only service role key. NEVER expose to the client.
# Used by Vercel serverless API routes under /api/admin/*.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret protecting /api/admin/*. The admin panel sends it as the
# x-admin-secret header. By convention, set this to the same value the admin
# UI uses for VITE_ADMIN_PASSWORD so the same login unlocks server writes.
ADMIN_SECRET=

# === Email backend (reception form) ===
# Use either Resend (recommended) OR SMTP. If both are set, Resend is used first.
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Recipients
DEFAULT_RECEPTION_EMAIL=info@meteo.uz
FROM_EMAIL=no-reply@meteo.uz

# === Frontend admin gate ===
# Password the admin panel asks for at /admin (kept on the client).
# For server writes to succeed, set ADMIN_SECRET to the same value.
VITE_ADMIN_USERNAME=
VITE_ADMIN_PASSWORD=admin
VITE_ADMIN_PIN=

# Optional reserved
VITE_API_URL=
VITE_PUBLIC_BASE_URL=

# ============================================================================
# Environment variables for UzHydromet
# ============================================================================
# Real values MUST live only in Vercel → Project Settings → Environment
# Variables (Production, Preview, Development), and locally in a `.env` /
# `.env.local` file that is git-ignored. NEVER commit real secrets.
#
# Frontend (browser) reads only `VITE_*` vars at build time.
# Serverless functions under /api/* read non-VITE vars at runtime.
# `SUPABASE_SERVICE_ROLE_KEY` MUST never appear in frontend code.
# ============================================================================

# --- Required: Supabase (frontend, public anon credentials) ----------------
# Safe to expose to the browser. Anon key is rate-limited and gated by RLS.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-jwt-here

# --- Required: Supabase (server-only) --------------------------------------
# NEVER expose this in frontend code. NEVER commit it. Bypasses RLS, full
# DB access. Used only by /api/admin/* serverless routes.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-jwt-here

# --- Required: Admin gate (server-only) ------------------------------------
# Shared secret. The admin panel sends it via the `x-admin-secret` header.
# By convention, set this to the same value as VITE_ADMIN_PASSWORD so the
# same login unlocks server writes.
ADMIN_SECRET=change-me

# --- Email backend (reception form, server-only) ---------------------------
# Use either Resend (recommended) OR SMTP. If both are set, Resend is used first.
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Recipients (server-only)
DEFAULT_RECEPTION_EMAIL=info@meteo.uz
FROM_EMAIL=no-reply@meteo.uz

# --- Frontend admin gate (browser) -----------------------------------------
# Password the admin panel asks for at /admin (kept on the client).
# For server writes to succeed, set ADMIN_SECRET to the same value.
VITE_ADMIN_USERNAME=
VITE_ADMIN_PASSWORD=change-me
VITE_ADMIN_PIN=

# --- Optional reserved (frontend) ------------------------------------------
VITE_API_URL=
VITE_PUBLIC_BASE_URL=

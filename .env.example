# === Email backend ===
# Use either Resend (recommended) OR SMTP. If both are set, Resend is used first.

# Resend
RESEND_API_KEY=

# SMTP (requires `nodemailer` to be installed at runtime)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Recipients
DEFAULT_RECEPTION_EMAIL=info@meteo.uz
FROM_EMAIL=no-reply@meteo.uz

# === Frontend ===
# Admin panel password (kept on the client; rotate as needed). Default: admin
VITE_ADMIN_PASSWORD=admin

# Optional Supabase (currently unused, reserved for future backend wiring)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
